# Local configuration
# Copy this file to local.yaml and modify as needed

service:
  name: blueprint
  version: v0.1.0

logger:
  disable: false
  level: debug
  encoding: pretty

tracing:
  exporter_host: localhost
  exporter_port: 4317

alert:
  provider: noop
  telegram_bot_token: token
  telegram_chat_ids: []

postgres:
  verbose: true
  host: localhost
  port: 5432
  user: postgres
  password: postgres
  database: blueprint

kafka_broker:
  brokers: localhost:9092

http_server:
  host: localhost
  port: 9876

# Module specific configs

auth:
  access_token_ttl: 24h
  refresh_token_ttl: 168h # 7 days
  max_active_sessions: 5
  worker_poll_interval: 1s
  hashing_cost: 10

filevault:
  max_file_size_mb: 10
  minio:
    endpoint: localhost:9000
    access_key: minioadmin
    secret_key: minioadmin
    bucket: blueprint

audit:
  worker_poll_interval: 1s

platform:
  worker_poll_interval: 1s
  alert_schema: alert
